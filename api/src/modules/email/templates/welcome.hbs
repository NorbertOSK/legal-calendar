{{#> layout title="Legal Calendar" dashboardUrl=dashboardUrl theme=theme}}
  <h1 style="margin:0 0 12px 0; font-size:28px; line-height:1.2; color:{{theme.textPrimary}}; text-transform:capitalize;">{{name}}, bienvenido!</h1>
  <p style="margin:0 0 12px 0; font-size:16px; line-height:1.6; color:{{theme.textSecondary}};">
    Bienvenido a <strong style="color:{{theme.textPrimary}};">Legal Calendar</strong>. Estamos muy contentos de tenerte con nosotros.
  </p>
  <p style="margin:0 0 20px 0; font-size:14px; line-height:1.6; color:{{theme.textSecondary}};">
    Tu panel ya está listo para que empieces a explorar tu experiencia en Legal Calendar.
  </p>
  <div style="text-align:center; margin-bottom:18px;">
    {{> button href=dashboardUrl label="Ir al panel" theme=theme}}
  </div>
  <p style="margin:0; font-size:13px; line-height:1.6; color:{{theme.textSecondary}};">
    Si necesitas ayuda, puedes acceder al panel en cualquier momento desde el enlace inferior.
  </p>
{{/layout}}
