<!DOCTYPE html>
<html lang="es">
<head>
  <meta http-equiv="Content-Type" content="text/html; charset=UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="color-scheme" content="light">
  <meta name="supported-color-schemes" content="light">
  <title>{{title}}</title>
</head>
<body style="margin:0; padding:0; background-color:{{theme.bodyBg}};" bgcolor="{{theme.bodyBg}}">
  <table role="presentation" width="100%" cellspacing="0" cellpadding="0" border="0" style="border-collapse:collapse; width:100%; background-color:{{theme.bodyBg}}; margin:0; padding:0;" bgcolor="{{theme.bodyBg}}">
    <tr>
      <td align="center" valign="top" style="margin:0; padding:0; background-color:{{theme.bodyBg}};" bgcolor="{{theme.bodyBg}}">
        <div bgcolor="{{theme.bodyBg}}" style="margin:0; padding:24px 12px; background-color:{{theme.bodyBg}}; font-family:Arial, Helvetica, sans-serif; color:{{theme.textPrimary}};">
          <div bgcolor="{{theme.cardBg}}" style="max-width:600px; margin:0 auto; background:{{theme.cardBg}}; border:1px solid {{theme.border}}; border-radius:12px; overflow:hidden;">
            <div style="padding:24px 24px 12px 24px;">
              {{> @partial-block}}
            </div>

            <hr style="margin:0; border:none; border-top:1px solid {{theme.border}};">

            <div style="padding:16px 24px; text-align:center;">
              <a href="{{dashboardUrl}}" target="_blank" style="color:{{theme.primary}}; text-decoration:none; font-weight:700;">
                Legal Calendar
              </a>
            </div>
          </div>
        </div>
      </td>
    </tr>
  </table>
</body>
</html>
