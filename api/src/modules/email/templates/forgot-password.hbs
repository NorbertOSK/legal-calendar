{{#> layout title="Legal Calendar" dashboardUrl=dashboardUrl theme=theme}}
  <h1 style="margin:0 0 12px 0; font-size:28px; line-height:1.2; color:{{theme.textPrimary}}; text-transform:capitalize;">{{name}}, recupera tu contraseña</h1>
  <p style="margin:0 0 12px 0; font-size:16px; line-height:1.6; color:{{theme.textSecondary}};">
    Ingresa al siguiente enlace para restablecer tu contraseña en <strong style="color:{{theme.textPrimary}};">Legal Calendar</strong>.
  </p>
  <p style="margin:0 0 20px 0; font-size:14px; line-height:1.6; color:{{theme.textSecondary}};">
    Solo dispones de 10 minutos para completar el proceso. Si expira, deberás generar una nueva solicitud.
  </p>
  <div style="text-align:center; margin-bottom:18px;">
    {{> button href=token label="Restablecer contraseña" theme=theme}}
  </div>
  <p style="margin:0 0 22px 0; font-size:13px; color:{{theme.textSecondary}}; line-height:1.6;">
    Si el botón no funciona, <a href="{{token}}" target="_blank" style="color:{{theme.primary}}; text-decoration:underline;">haz clic aquí</a>.
  </p>
  <p style="margin:0; font-size:13px; line-height:1.6; color:{{theme.textSecondary}};">Gracias.</p>
{{/layout}}
