{{#> layout title="Legal Calendar" dashboardUrl=dashboardUrl theme=theme}}
  <h1 style="margin:0 0 12px 0; font-size:28px; line-height:1.2; color:{{theme.textPrimary}}; text-transform:capitalize;">{{name}}, tu contraseña fue actualizada</h1>
  <p style="margin:0 0 12px 0; font-size:16px; line-height:1.6; color:{{theme.textSecondary}};">
    Tu contraseña en <strong style="color:{{theme.textPrimary}};">Legal Calendar</strong> ha sido actualizada exitosamente.
  </p>
  <p style="margin:0 0 22px 0; font-size:13px; color:{{theme.textSecondary}}; line-height:1.6;">
    Si no realizaste este cambio, contáctanos inmediatamente.
  </p>
{{/layout}}
